<?xml version="1.0" encoding="UTF-8" ?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <persistence-unit name="myPersistenceUnit" transaction-type="RESOURCE_LOCAL">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>entity.User</class>
        <class>entity.Product</class>
        <class>entity.CartItem</class>

        <properties>
            <!-- ── JDBC Driver ──────────────────────────────────────────── -->
            <property name="jakarta.persistence.jdbc.driver"
                      value="com.mysql.cj.jdbc.Driver"/>

            <!--
                Fallback values for local development only.
                On Render, JPAUtil overrides these at runtime using
                DB_URL / DB_USERNAME / DB_PASSWORD environment variables.
            -->
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/ecommerce_db?createDatabaseIfNotExist=true&amp;useSSL=false&amp;serverTimezone=UTC&amp;allowPublicKeyRetrieval=true"/>
            <property name="jakarta.persistence.jdbc.user"     value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="root"/>

            <!-- ── Hibernate core ────────────────────────────────────────── -->
            <property name="hibernate.dialect"      value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql"     value="false"/>

            <!--
                ── HikariCP Connection Pool ──────────────────────────────────
                Tell Hibernate to delegate connection management to HikariCP.
                This is the only way to TRULY enforce maximumPoolSize.
                Hibernate's built-in pool ignores hibernate.connection.pool_size
                in multi-threaded web apps and can exceed the limit.
            -->
            <property name="hibernate.connection.provider_class"
                      value="org.hibernate.hikari.HikariConnectionProvider"/>

            <!--
                FreeSQLDatabase free tier allows ~3 simultaneous connections.
                maximumPoolSize = 3  →  hard cap; the 4th request waits in queue.
                minimumIdle     = 1  →  keep 1 warm connection alive at all times.
                connectionTimeout   →  throw after 20 s if no connection available
                                       (better than hanging forever).
                idleTimeout         →  release idle connections after 5 min to
                                       avoid FreeSQLDatabase's 8-hour disconnect.
                maxLifetime         →  recycle connections every 25 min to stay
                                       under MySQL's wait_timeout.
                keepaliveTime       →  ping idle connections every 2 min so the
                                       remote server doesn't close them silently.
            -->
            <property name="hibernate.hikari.maximumPoolSize"  value="3"/>
            <property name="hibernate.hikari.minimumIdle"      value="1"/>
            <property name="hibernate.hikari.connectionTimeout" value="20000"/>
            <property name="hibernate.hikari.idleTimeout"      value="300000"/>
            <property name="hibernate.hikari.maxLifetime"      value="1500000"/>
            <property name="hibernate.hikari.keepaliveTime"    value="120000"/>

            <!-- Validate the connection before handing it to Hibernate -->
            <property name="hibernate.hikari.connectionTestQuery"
                      value="SELECT 1"/>

            <!-- ── Disable unused caches ─────────────────────────────────── -->
            <property name="hibernate.cache.use_second_level_cache" value="false"/>
            <property name="hibernate.cache.use_query_cache"        value="false"/>
        </properties>

    </persistence-unit>
</persistence>
