<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

  <!--
    Welcome-file list: Tomcat consults this when the request path is a
    directory.  Having index.jsp here is correct and kept as a safety net.
    The explicit RootServlet mapping below takes priority for the exact path "/".
  -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!--
    RootServlet — maps the bare context root ("/") to index.jsp via a forward.
    This is more reliable than depending on Tomcat's welcome-file lookup, which
    can return 404 if the WAR is still being unpacked (async deployment) or if
    the DefaultServlet's directory listing is disabled.
  -->
  <servlet>
    <servlet-name>RootServlet</servlet-name>
    <servlet-class>servlet.RootServlet</servlet-class>
    <load-on-startup>1</load-on-startup>
  </servlet>
  <servlet-mapping>
    <servlet-name>RootServlet</servlet-name>
    <url-pattern>/</url-pattern>
  </servlet-mapping>

  <!-- JPA lifecycle: initialises HikariCP pool on startup, drains it on shutdown -->
  <listener>
    <listener-class>util.AppLifecycleListener</listener-class>
  </listener>

  <!-- Auth -->
  <servlet><servlet-name>LoginServlet</servlet-name><servlet-class>servlet.LoginServlet</servlet-class></servlet>
  <servlet-mapping><servlet-name>LoginServlet</servlet-name><url-pattern>/LoginServlet</url-pattern></servlet-mapping>

  <servlet><servlet-name>LogoutServlet</servlet-name><servlet-class>servlet.LogoutServlet</servlet-class></servlet>
  <servlet-mapping><servlet-name>LogoutServlet</servlet-name><url-pattern>/LogoutServlet</url-pattern></servlet-mapping>

  <!-- Registration -->
  <servlet><servlet-name>UserRegisterServlet</servlet-name><servlet-class>servlet.UserRegisterServlet</servlet-class></servlet>
  <servlet-mapping><servlet-name>UserRegisterServlet</servlet-name><url-pattern>/UserRegisterServlet</url-pattern></servlet-mapping>

  <servlet><servlet-name>VendorRegisterServlet</servlet-name><servlet-class>servlet.VendorRegisterServlet</servlet-class></servlet>
  <servlet-mapping><servlet-name>VendorRegisterServlet</servlet-name><url-pattern>/VendorRegisterServlet</url-pattern></servlet-mapping>

  <!-- Product Management -->
  <servlet><servlet-name>AddProductServlet</servlet-name><servlet-class>servlet.AddProductServlet</servlet-class></servlet>
  <servlet-mapping><servlet-name>AddProductServlet</servlet-name><url-pattern>/AddProductServlet</url-pattern></servlet-mapping>

  <servlet><servlet-name>UpdateProductServlet</servlet-name><servlet-class>servlet.UpdateProductServlet</servlet-class></servlet>
  <servlet-mapping><servlet-name>UpdateProductServlet</servlet-name><url-pattern>/UpdateProductServlet</url-pattern></servlet-mapping>

  <servlet><servlet-name>DeleteProductServlet</servlet-name><servlet-class>servlet.DeleteProductServlet</servlet-class></servlet>
  <servlet-mapping><servlet-name>DeleteProductServlet</servlet-name><url-pattern>/DeleteProductServlet</url-pattern></servlet-mapping>

  <!-- Stock Management -->
  <servlet><servlet-name>UpdateStockServlet</servlet-name><servlet-class>servlet.UpdateStockServlet</servlet-class></servlet>
  <servlet-mapping><servlet-name>UpdateStockServlet</servlet-name><url-pattern>/UpdateStockServlet</url-pattern></servlet-mapping>

  <!-- User Management -->
  <servlet><servlet-name>DeleteUserServlet</servlet-name><servlet-class>servlet.DeleteUserServlet</servlet-class></servlet>
  <servlet-mapping><servlet-name>DeleteUserServlet</servlet-name><url-pattern>/DeleteUserServlet</url-pattern></servlet-mapping>

  <!-- Vendor Verification -->
  <servlet><servlet-name>VerifyVendorServlet</servlet-name><servlet-class>servlet.VerifyVendorServlet</servlet-class></servlet>
  <servlet-mapping><servlet-name>VerifyVendorServlet</servlet-name><url-pattern>/VerifyVendorServlet</url-pattern></servlet-mapping>

  <!-- Cart -->
  <servlet><servlet-name>CartServlet</servlet-name><servlet-class>servlet.CartServlet</servlet-class></servlet>
  <servlet-mapping><servlet-name>CartServlet</servlet-name><url-pattern>/CartServlet</url-pattern></servlet-mapping>

  <!-- Buy Now -->
  <servlet><servlet-name>BuyNowServlet</servlet-name><servlet-class>servlet.BuyNowServlet</servlet-class></servlet>
  <servlet-mapping><servlet-name>BuyNowServlet</servlet-name><url-pattern>/BuyNowServlet</url-pattern></servlet-mapping>

  <!--
    Error pages: send friendly responses instead of bare Tomcat error pages.
    The 404 page forwards back to the root; the 500 page stays to show the error.
  -->
  <error-page>
    <error-code>404</error-code>
    <location>/index.jsp</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/error.jsp</location>
  </error-page>

</web-app>
